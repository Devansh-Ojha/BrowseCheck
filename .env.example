# Copy to .env and fill in.  Never commit real keys.

# Control-loop environment seam: LOCAL (fast dev) | BROWSERBASE (demo)
ENV=LOCAL

# Browserbase (required when ENV=BROWSERBASE)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Anthropic — powers the two hero hooks
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Observability (OPTIONAL): when set, the SentrySink turns on automatically.
# Leave blank for the naive/no-Sentry path.
SENTRY_DSN=

# Dashboard server
PORT=8000

# Demo poisoned page (must be reachable by the Browserbase cloud browser).
# Preferred: the red team's hosted portal URL.
REDTEAM_URL=
# Fallback: a PUBLIC base URL that serves our tests/fixtures (e.g. a tunnel to
# this server: `cloudflared tunnel --url http://localhost:8000`). The injection
# fixture is then used at <FIXTURE_BASE_URL>/fixtures/injection_invisible.html
FIXTURE_BASE_URL=
